{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".github/**",
      "README.md",
      ".gitignore",
      "zai-config.example.js"
    ],
    "rewrites": [
      {
        "source": "/Zakhourani.AI.Html",
        "destination": "/Zakhourani.AI.Html"
      },
      {
        "source": "/ai",
        "destination": "/Zakhourani.AI.Html"
      },
      {
        "source": "/zakhourani",
        "destination": "/Zakhourani.AI.Html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.@(svg|png|jpg|ico|woff2|woff)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=86400"
          }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src * 'unsafe-inline' 'unsafe-eval'; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; img-src * data: https:; font-src * data: https:; connect-src * https://wkgldyfxsmkjyallrdtq.supabase.co https://aged-recipe-80db.wabdo3762.workers.dev https://www.googleapis.com https://securetoken.googleapis.com https://identitytoolkit.googleapis.com; frame-src *"
          }
        ]
      }
    ]
  }
}
